    "prisma:validate": "node scripts/prisma-env.mjs validate",
    "start": "next start",
    "lint": "eslint .",
    "seed:lexicon": "node prisma/seed-lexicon.mjs",
    "lexicon:extract-demo-labels": "node scripts/extract-demo-labels.mjs",
    "lexicon:import-phase1": "node scripts/import-phase1-lexemes.mjs",
    "test:phase1-battery": "node scripts/test-phase1-battery.mjs",
    "test:lexicon-regression": "node scripts/test-lexicon-regression.mjs",
