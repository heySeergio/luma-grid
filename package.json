    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "stripe": "^21.0.1",
    "tailwind-merge": "^3.5.0"
