    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5.22.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "framer-motion": "^12.38.0",
    "jose": "^4.15.9",
