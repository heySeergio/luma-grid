{
  "name": "luma-grid",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/prisma-env.mjs generate",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "clean": "node scripts/clean-next.js",
    "dev:clean": "npm run clean && npm run dev",
    "build": "node scripts/prisma-env.mjs generate && next build --webpack && node scripts/write-routes-manifest-deterministic.mjs",
    "build:with-migrate": "node scripts/prisma-migrate-deploy.mjs && node scripts/prisma-env.mjs generate && next build --webpack && node scripts/write-routes-manifest-deterministic.mjs",
    "migrate:deploy": "node scripts/prisma-migrate-deploy.mjs",
    "migrate:resolve": "node scripts/prisma-env.mjs migrate resolve",
    "prisma:generate": "node scripts/prisma-env.mjs generate",
    "prisma:validate": "node scripts/prisma-env.mjs validate",
    "start": "next start",
    "lint": "eslint .",
    "seed:lexicon": "node prisma/seed-lexicon.mjs",
    "lexicon:extract-demo-labels": "node scripts/extract-demo-labels.mjs",
    "lexicon:import-phase1": "node scripts/import-phase1-lexemes.mjs",
    "test:phase1-battery": "node scripts/test-phase1-battery.mjs",
    "test:lexicon-regression": "node scripts/test-lexicon-regression.mjs",
    "lexicon:generate-phase2-data": "node scripts/generate-phase2-bulk-data.mjs",
    "lexicon:import-phase2": "node scripts/import-phase2-lexemes.mjs",
    "lexicon:validate-phase3": "node scripts/validate-phase3-staging.mjs",
    "lexicon:import-phase3": "node scripts/import-phase3-lexemes.mjs",
    "db:migrate": "node scripts/prisma-migrate-envlocal.mjs",
    "db:migrate:dev": "node scripts/prisma-env.mjs migrate dev",
    "migrate:sqlite-user": "node scripts/migrate-sqlite-user-to-neon.mjs",
    "test:lexicon-detection": "npx tsx scripts/test-lexicon-detection.mjs",
    "test:mejora-plan": "node scripts/test-mejora-plan.mjs",
    "repair:demo-email": "node scripts/repair-demo-by-email.mjs",
    "reset:demo-board": "npx tsx --tsconfig tsconfig.json scripts/reset-demo-board-by-email.ts",
    "arasaac:download-main-grid": "npx tsx --tsconfig tsconfig.json scripts/download-arasaac-main-grid-pngs.ts",
    "test:admin-move": "npx tsx --test lib/admin/applyAdminSymbolGridMove.test.ts",
    "test:utterance-metrics": "npx tsx --test lib/usageEvaluation/utteranceMetrics.test.ts",
    "test:lexicon-usage": "npx tsx --test lib/usageEvaluation/aggregates/lexiconUsage.test.ts",
    "test:communication-eval": "npx tsx --test lib/usageEvaluation/aggregates/communicationEvaluation.test.ts",
    "test:vocabulary-adoption": "npx tsx --test lib/usageEvaluation/aggregates/vocabularyAdoption.test.ts",
    "test:navigation-friction": "npx tsx --test lib/usageEvaluation/aggregates/navigationFriction.test.ts",
    "test:auth-crypto": "npx tsx --test lib/auth/crypto.test.ts",
    "test:auth-totp": "npx tsx --test lib/auth/twoFactor.test.ts"
  },
  "prisma": {
    "seed": "node prisma/seed-lexicon.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@opentelemetry/api": "^1.9.1",
    "@prisma/client": "^5.22.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "framer-motion": "^12.38.0",
    "jose": "^4.15.9",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.6.0",
    "md5": "^2.3.0",
    "next": "16.2.2",
    "next-auth": "^4.24.13",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "otpauth": "^9.5.1",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "stripe": "^21.0.1",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/md5": "^2.3.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "better-sqlite3": "^12.8.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
