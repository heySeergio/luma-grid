# Neon / PostgreSQL (pooler recomendado para la app; migraciones suelen usar conexión directa)
# En local suele ir en .env.local. Prisma CLI solo carga .env por defecto.
# Usa `npm run db:migrate` (migraciones leyendo .env.local) o `npm run prisma:generate` / `npm run prisma:validate`
# (scripts/prisma-env.mjs carga .env y luego .env.local para evitar P1012).
#
# Vercel / CI: `npm run build` no ejecuta migraciones (evita P1002 timeout en build). Tras cambios de schema,
# aplica migraciones en producción con `npm run migrate:deploy` usando DATABASE_URL de producción, o Neon SQL Editor.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Migración puntual: copiar usuario desde SQLite local a Neon (ver npm run migrate:sqlite-user)
# SQLITE_PATH=prisma/dev.db
# MIGRATE_EMAIL=correo@ejemplo.com
# MIGRATE_REPLACE=1

# NextAuth — obligatorio en producción (URL pública exacta, p. ej. https://www.tudominio.com)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# SEO: URL canónica (Open Graph, sitemap, JSON-LD). En Vercel se usa VERCEL_URL si no está definida.
# NEXT_PUBLIC_SITE_URL=https://www.tudominio.com
# Verificación Google Search Console (meta tag; opcional)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Imagen Open Graph / Twitter (URL absoluta; opcional si usas /og/social o subida a Supabase)
# NEXT_PUBLIC_OG_IMAGE_URL=https://...
# NEXT_PUBLIC_OG_IMAGE_WIDTH=1200
# NEXT_PUBLIC_OG_IMAGE_HEIGHT=630

# Subida en /og/subir — token compartido servidor/cliente (obligatorio para el formulario)
# OG_UPLOAD_SECRET=genera-un-string-largo-aleatorio

# Bucket Supabase para subir OG en producción (lectura pública del objeto)
# SUPABASE_OG_BUCKET=public

# Google OAuth. Consola: APIs y servicios → Credenciales → ID de cliente OAuth 2.0
# URI de redirección: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# ElevenLabs (solo servidor; TTS preset/custom y clonación de voz)
ELEVENLABS_API_KEY=

# Stripe — checkout, portal (POST /api/stripe/portal) y webhooks: /api/stripe/webhook o /api/webhooks/stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Productos (prod_…) — para mapear suscripción → plan voz / identidad
STRIPE_PRODUCT_VOZ=
STRIPE_PRODUCT_IDENTIDAD=
# Precios (price_…) — nombres preferidos (también se aceptan STRIPE_PRICE_VOICE_* / STRIPE_PRICE_IDENTITY_*)
STRIPE_PRICE_VOZ_MONTHLY=
STRIPE_PRICE_VOZ_YEARLY=
STRIPE_PRICE_IDENTIDAD_MONTHLY=
STRIPE_PRICE_IDENTIDAD_YEARLY=
# Legacy (opcional)
# STRIPE_PRICE_VOICE_MONTHLY=
# STRIPE_PRICE_VOICE_YEARLY=
# STRIPE_PRICE_IDENTITY_MONTHLY=
# STRIPE_PRICE_IDENTITY_YEARLY=
